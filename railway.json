{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd backend && npm ci --legacy-peer-deps && npm run build"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "bash start.sh",
    "restartPolicyMaxRetries": 3,
    "restartPolicyWindowMs": 60000
  }
}
