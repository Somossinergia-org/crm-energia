# ========================================
# ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill with real values
# ========================================

# ========================================
# DATABASE - SUPABASE (PostgreSQL)
# ========================================
# Get these from: https://supabase.com/dashboard
# Settings → Database → Connection String

# Full PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Individual database connection details
DB_HOST=db.xxxxx.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_supabase_password
DB_NAME=postgres

# ========================================
# REDIS CACHE (Optional but recommended)
# ========================================
# Leave empty to disable Redis
REDIS_URL=redis://localhost:6379

# ========================================
# NODE ENVIRONMENT
# ========================================
NODE_ENV=production
PORT=3000

# ========================================
# JWT AUTHENTICATION
# ========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_min_32_characters
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_characters
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Encryption key for sensitive data (min 16 chars)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your_encryption_key_min_16_characters

# ========================================
# GEMINI AI API
# ========================================
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ========================================
# EMAIL CONFIGURATION (Optional)
# ========================================
# Gmail: Enable 2FA and create App Password
# https://myaccount.google.com/apppasswords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM=noreply@tuempresa.com

# ========================================
# CORS & SECURITY
# ========================================
# Frontend URL - Must match exactly for CORS
CORS_ORIGIN=https://crm-energia.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=info
LOG_DIR=./logs

# ========================================
# FRONTEND CONFIGURATION
# ========================================
# This goes in frontend/.env
VITE_API_URL=https://crm-energia-api.onrender.com/api
VITE_APP_NAME=CRM Energía

# ========================================
# OPTIONAL FEATURES
# ========================================
# Enable/disable modules
ENABLE_EMAIL_TRACKING=true
ENABLE_WEBHOOKS=true
ENABLE_NOTIFICATIONS=true

# ========================================
# SECURITY NOTES
# ========================================
# NEVER commit this file to git
# Add .env to .gitignore
# Use environment variables in production
# Rotate JWT secrets periodically
# Keep GEMINI_API_KEY secret
