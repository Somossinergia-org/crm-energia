{
  "version": 2,
  "buildCommand": "bash build.sh",
  "installCommand": "echo 'Skipping root install - build.sh runs npm ci in backend/ and frontend/'",
  "framework": "vite",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/api"
    }
  ]
}
