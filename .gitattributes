# Normalizar line endings automaticamente
* text=auto eol=lf

# Forzar LF en estos archivos siempre
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.sql   text eol=lf
*.env*  text eol=lf

# Binarios - no tocar
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
